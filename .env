APP_ENV=development

# AWS / S3
AWS_PROFILE=
AWS_REGION=
S3_BUCKET=
S3_PREFIX=

# ADLS Gen2
ADLS_ACCOUNT_URL=
ADLS_FILE_SYSTEM=
ADLS_PREFIX=
ADLS_SAS_TOKEN=
# ADLS_CONNECTION_STRING=

# Optional: Hugging Face token for higher rate limits
HF_TOKEN=

# Optional: Matplotlib cache dir (use a writable path to avoid warnings)
MPLCONFIGDIR=/tmp/matplotlib-cache
CLOUD_SYNC_INTERVAL_SECONDS=60
HOST=0.0.0.0
PORT=80
